{
  "entities": {
    "CommunityRegistration": {
      "title": "CommunityRegistration",
      "description": "User registration record for the Siam Cyber community",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique Firebase Auth identifier of the user"
        },
        "name": {
          "type": "string",
          "description": "The display name of the registered user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the registered user"
        },
        "registeredAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp indicating when they registered"
        }
      },
      "required": ["uid", "name", "email", "registeredAt"]
    },
    "PageView": {
      "title": "PageView",
      "description": "Analytics tracking for daily site views",
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the view occurred"
        },
        "country": {
          "type": "string",
          "description": "Approximate country of origin"
        },
        "email": {
          "type": "string",
          "description": "Active user's email or Guest"
        },
        "timezone": {
          "type": "string",
          "description": "Active timezone"
        }
      },
      "required": ["timestamp", "country", "email", "timezone"]
    },
    "FreeSource": {
      "title": "FreeSource",
      "description": "User suggested or default open source utility proxy / tool",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the free tool"
        },
        "url": {
          "type": "string",
          "description": "GitHub/Access link for the free tool"
        },
        "description": {
          "type": "string",
          "description": "Explaining paragraph for the tool"
        },
        "category": {
          "type": "string",
          "description": "Categorized label"
        },
        "tags": {
          "type": "array",
          "description": "Sub-keywords for searches"
        },
        "instructions": {
          "type": "array",
          "description": "Detailed setup instruction steps"
        },
        "stars": {
          "type": "string",
          "description": "GitHub stars count or contribution banner"
        },
        "author": {
          "type": "string",
          "description": "Name of author or contributor"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Time of contribution"
        },
        "userId": {
          "type": "string",
          "description": "Contributor auth identifier"
        }
      },
      "required": ["name", "url", "description", "category", "tags", "instructions", "stars", "author", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/community_registrations/{registrationId}": {
      "schema": "CommunityRegistration",
      "description": "Secure community member registrations"
    },
    "/page_views/{viewId}": {
      "schema": "PageView",
      "description": "Realtime page analytics logs for administration overview"
    },
    "/free_sources/{sourceId}": {
      "schema": "FreeSource",
      "description": "Free open-source tools and setup references"
    }
  }
}
