rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Default Deny Catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'fahimmuntasir12390@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity-Specific Validation Helper (CommunityRegistration)
    function isValidCommunityRegistration(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'registeredAt']) &&
             data.keys().size() == 4 &&
             data.uid is string &&
             data.uid == request.auth.uid &&
             data.name is string &&
             data.name.size() >= 2 &&
             data.name.size() <= 100 &&
             data.email is string &&
             data.email.size() >= 3 &&
             data.email.size() <= 200 &&
             data.registeredAt is timestamp &&
             data.registeredAt == request.time;
    }

    // PageView Validation Helper
    function isValidPageView(data) {
      return data.keys().hasAll(['timestamp', 'country', 'email', 'timezone']) &&
             data.keys().size() == 4 &&
             data.timestamp is timestamp &&
             data.timestamp == request.time &&
             data.country is string &&
             data.country.size() <= 100 &&
             data.email is string &&
             data.email.size() <= 256 &&
             data.timezone is string &&
             data.timezone.size() <= 100;
    }

    // free_sources Validation Helper
    function isValidFreeSource(data) {
      return data.keys().hasAll(['name', 'url', 'description', 'category', 'tags', 'instructions', 'stars', 'author', 'createdAt', 'userId']) &&
             data.name is string &&
             data.name.size() >= 2 && data.name.size() <= 100 &&
             data.url is string &&
             data.url.size() >= 5 && data.url.size() <= 500 &&
             data.description is string &&
             data.description.size() >= 5 && data.description.size() <= 2000 &&
             data.category is string &&
             data.tags is list &&
             data.instructions is list &&
             data.stars is string &&
             data.author is string &&
             data.userId is string;
    }

    // Collection Security: Registrations
    match /community_registrations/{registrationId} {
      allow read: if isSignedIn() && (registrationId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidId(registrationId) && 
                    registrationId == request.auth.uid && 
                    isValidCommunityRegistration(incoming());

      allow update: if isSignedIn() && 
                    isValidId(registrationId) && 
                    isOwner(existing().uid) && 
                    incoming().uid == existing().uid &&
                    isValidCommunityRegistration(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'registeredAt']);

      allow delete: if isAdmin(); // Only admins can remove registrations if needed
    }

    // Collection Security: Page Analytics
    match /page_views/{viewId} {
      allow create: if isValidId(viewId) && isValidPageView(incoming());
      allow read: if isAdmin();
    }

    // Collection Security: Free Sources Hub
    match /free_sources/{sourceId} {
      allow read: if true;
      allow create: if isValidId(sourceId) && isValidFreeSource(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
